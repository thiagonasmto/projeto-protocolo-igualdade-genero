{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "framework": "nextjs",
      "root": "frontend",
      "routePrefix": "/"
    },
    "backend": {
      "framework": "django",
      "root": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/_/backend/api/$1"
    }
  ]
}
